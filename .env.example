# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Database (Neon Postgres)
DATABASE_URL=

# Internal gondoor backend secret (used to authorize POST /api/site-config/html)
GONDOOR_INTERNAL_SECRET=

# Whop ecommerce (provisioned by gondoor backend)
WHOP_API_KEY=
WHOP_API_BASE=https://api.whop.com
WHOP_WEBHOOK_SECRET=

# Gondoor SaaS app billing proxy (provisioned by gondoor backend)
GONDOOR_API_BASE=
GONDOOR_TENANT_ID=
GONDOOR_SAAS_APP_API_KEY=
GONDOOR_SAAS_VERIFICATION_SECRET=
# Optional: set to test to force Whop test mode for live SaaS app keys
GONDOOR_SAAS_MODE=
